{
  "name": "wilsonchao-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @wilson/main",
    "dev:main": "npm run dev -w @wilson/main",
    "build": "npm run build -w @wilson/main",
    "build:main": "npm run build -w @wilson/main",
    "lint": "npm run lint --workspaces --if-present",
    "sync:notion": "npm run sync:notion -w @wilson/main",
    "sync:vault": "npm run sync:vault -w @wilson/main",
    "sync:drawer": "npm run sync:drawer -w @wilson/main",
    "sync:taste": "npm run sync:taste -w @wilson/main",
    "watchdog:drawer": "npm run watchdog:drawer -w @wilson/main"
  }
}
