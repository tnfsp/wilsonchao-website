# Obsidian vault sync (scripts/sync-vault.ts)
# Optional: absolute path to your Obsidian vault root.
# Defaults to the iCloud vault (~/Library/Mobile Documents/iCloud~md~obsidian/Documents/Wilson) when unset.
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

NOTION_TOKEN=your-notion-integration-token
NOTION_BLOG_DATABASE_ID=your-blog-database-id
NOTION_SITE_CONFIG_DATABASE_ID=your-site-config-database-id
# Optional: set to enable projects sync; keep blank to skip
NOTION_PROJECTS_DATABASE_ID=your-projects-database-id

# Comments (giscus - GitHub Discussions)
NEXT_PUBLIC_GISCUS_REPO=tnfsp/new_website
NEXT_PUBLIC_GISCUS_REPO_ID=your-repo-id
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=your-category-id
# optional: preferred_color_scheme | light | light_high_contrast | dark | transparent_dark | ...
NEXT_PUBLIC_GISCUS_THEME=preferred_color_scheme
NEXT_PUBLIC_GISCUS_LANG=zh-TW
# 1 for strict matching, 0 to allow fuzzy; default 0
NEXT_PUBLIC_GISCUS_STRICT=0
# Mapping strategy: pathname (default) | url | title | og:title | specific
NEXT_PUBLIC_GISCUS_MAPPING=pathname

# 週報電子報（Resend — 訂閱 route + scripts/send-newsletter.ts）
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_SEGMENT_ID=your-segment-id          # Resend dashboard > Segments
# RESEND_FROM="Wilson Chao <hi@wilsonchao.com>"  # 選填，需先在 Resend 驗證網域
# RESEND_REPLY_TO=you@example.com            # 選填，訂閱者回信會寄到這裡

# 訂閱名單也寫入 KV 作歷史紀錄（production 由 Vercel 自動注入）
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
